# Copy this file to .streamlit/secrets.toml and fill in your values
# NEVER commit secrets.toml to git

# OpenRouter API Key (get free key at https://openrouter.ai)
OPENROUTER_API_KEY = "sk-or-v1-your-key-here"

# Supabase credentials (get from https://supabase.com/dashboard)
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-anon-public-key-here"
